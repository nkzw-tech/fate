{
  "name": "vue-fate",
  "version": "1.1.0",
  "description": "fate is a modern data client for Vue.",
  "homepage": "https://github.com/nkzw-tech/fate",
  "license": "MIT",
  "author": {
    "name": "Christoph Nakazawa",
    "email": "christoph.pojer@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nkzw-tech/fate"
  },
  "bin": {
    "fate": "./lib/cli.mjs"
  },
  "files": [
    "docs",
    "lib"
  ],
  "type": "module",
  "main": "./lib/index.mjs",
  "types": "./lib/index.d.mts",
  "exports": {
    ".": {
      "types": "./lib/index.d.mts",
      "@nkzw/source": "./src/index.ts",
      "default": "./lib/index.mjs"
    },
    "./client": {
      "types": "./lib/client.d.mts",
      "@nkzw/source": "./src/client.ts",
      "default": "./lib/client.mjs"
    },
    "./vite": {
      "types": "./lib/vite.d.mts",
      "@nkzw/source": "./src/vite.ts",
      "default": "./lib/vite.mjs"
    }
  },
  "scripts": {
    "build": "vp pack -d lib --target=node24 src/index.ts src/client.ts src/cli.ts src/vite.ts"
  },
  "dependencies": {
    "@nkzw/fate": "workspace:^"
  },
  "devDependencies": {
    "vue": "^3.5.35"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
