{
  "name": "cf-fate",
  "version": "1.3.1",
  "description": "Cloudflare adapter for fate.",
  "homepage": "https://github.com/nkzw-tech/fate",
  "license": "MIT",
  "author": {
    "name": "Christoph Nakazawa",
    "email": "christoph.pojer@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nkzw-tech/fate",
    "directory": "packages/cf-fate"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "main": "./lib/index.mjs",
  "types": "./lib/index.d.mts",
  "exports": {
    ".": {
      "types": "./lib/index.d.mts",
      "@nkzw/source": "./src/index.ts",
      "default": "./lib/index.mjs"
    },
    "./client": {
      "types": "./lib/client.d.mts",
      "@nkzw/source": "./src/client.ts",
      "default": "./lib/client.mjs"
    },
    "./server": {
      "types": "./lib/server.d.mts",
      "@nkzw/source": "./src/server.ts",
      "default": "./lib/server.mjs"
    }
  },
  "scripts": {
    "build": "vp pack -d lib --target=node24 src/index.ts src/client.ts src/server.ts"
  },
  "dependencies": {
    "@nkzw/fate": "^1.3.1"
  },
  "devDependencies": {
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@nkzw/fate": "^1.0.0-rc.0"
  }
}
