{
  "name": "fate-app",
  "version": "0.0.1",
  "private": true,
  "description": "fate is a modern data client for React.",
  "author": "Christoph Nakazawa <christoph.pojer@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git://github.com/nkzw-tech/fate.git"
  },
  "type": "module",
  "scripts": {
    "build": "vp build",
    "db:generate": "void db generate",
    "db:migrate": "void db migrate",
    "db:seed": "void db seed --file db/seed.ts",
    "dev": "vp dev",
    "dev:setup": "vp run prepare:void && vp run db:seed && vp run fate:generate",
    "fate:generate": "vp exec fate generate",
    "prepare:void": "void prepare"
  },
  "dependencies": {
    "@nkzw/core": "^1.3.1",
    "@nkzw/fate": "latest",
    "@nkzw/stack": "^2.3.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@void/react": "^0.7.4",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-fate": "latest",
    "tailwind-merge": "^3.5.0",
    "void": "^0.7.4",
    "void-fate": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.4",
    "ts-node": "^10.9.2",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ],
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.0.6"
}
