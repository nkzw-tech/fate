{
  "name": "@nkzw/fate",
  "version": "0.1.3",
  "description": "fate is a modern data client for React.",
  "homepage": "https://github.com/nkzw-tech/fate",
  "license": "MIT",
  "author": {
    "name": "Christoph Nakazawa",
    "email": "christoph.pojer@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nkzw-tech/fate"
  },
  "bin": {
    "fate": "./lib/cli.mjs"
  },
  "files": [
    "docs",
    "lib"
  ],
  "type": "module",
  "main": "./lib/index.mjs",
  "types": "./lib/index.d.mts",
  "exports": {
    ".": {
      "types": "./lib/index.d.mts",
      "@nkzw/source": "./src/index.ts",
      "default": "./lib/index.mjs"
    },
    "./client": {
      "types": "./lib/clientStub.d.mts",
      "@nkzw/source": "./src/clientStub.ts",
      "default": "./lib/clientStub.mjs"
    },
    "./cli": {
      "types": "./lib/cli.d.mts",
      "@nkzw/source": "./src/cli.ts",
      "default": "./lib/cli.mjs"
    },
    "./server": {
      "types": "./lib/server.d.mts",
      "@nkzw/source": "./src/server.ts",
      "default": "./lib/server.mjs"
    },
    "./server/drizzle": {
      "types": "./lib/server/drizzle.d.mts",
      "@nkzw/source": "./src/server/drizzle.ts",
      "default": "./lib/server/drizzle.mjs"
    },
    "./server/prisma": {
      "types": "./lib/server/prisma.d.mts",
      "@nkzw/source": "./src/server/prisma.ts",
      "default": "./lib/server/prisma.mjs"
    },
    "./vite": {
      "types": "./lib/vite.d.mts",
      "@nkzw/source": "./src/vite.ts",
      "default": "./lib/vite.mjs"
    }
  },
  "scripts": {
    "build": "vp pack -d lib --target=node24 src/index.ts src/clientStub.ts src/cli.ts src/server.ts src/server/drizzle.ts src/server/prisma.ts src/vite.ts"
  },
  "dependencies": {
    "superjson": "^2.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "drizzle-orm": "^0.45.2",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@trpc/client": "^11.6.0",
    "drizzle-orm": "^0.45.0",
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}
