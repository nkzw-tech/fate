{
  "name": "void-fate",
  "version": "1.0.0",
  "description": "Void adapter for fate.",
  "homepage": "https://github.com/nkzw-tech/fate",
  "license": "MIT",
  "author": {
    "name": "Christoph Nakazawa",
    "email": "christoph.pojer@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nkzw-tech/fate",
    "directory": "packages/void-fate"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "main": "./lib/index.mjs",
  "types": "./lib/index.d.mts",
  "exports": {
    ".": {
      "types": "./lib/index.d.mts",
      "@nkzw/source": "./src/index.ts",
      "default": "./lib/index.mjs"
    },
    "./react": {
      "types": "./lib/react.d.mts",
      "@nkzw/source": "./src/react.tsx",
      "default": "./lib/react.mjs"
    },
    "./server": {
      "types": "./lib/server.d.mts",
      "@nkzw/source": "./src/server.ts",
      "default": "./lib/server.mjs"
    }
  },
  "scripts": {
    "build": "vp pack -d lib --target=node24 src/index.ts src/react.tsx src/server.ts"
  },
  "dependencies": {
    "@nkzw/fate": "workspace:^",
    "react-fate": "workspace:^"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.6",
    "void": "^0.7.5"
  },
  "peerDependencies": {
    "@nkzw/fate": "^1.0.0-rc.0",
    "react": "^19.2.0",
    "react-fate": "^1.0.0-rc.0",
    "void": "^0.7.5"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-fate": {
      "optional": true
    }
  }
}
