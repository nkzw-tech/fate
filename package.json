{
  "name": "@nkzw/fate-private",
  "version": "1.0.0",
  "private": true,
  "description": "fate is a modern data client for React.",
  "author": "Christoph Nakazawa <christoph.pojer@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git://github.com/nkzw-tech/fate.git"
  },
  "type": "module",
  "scripts": {
    "build:all": "vp run -r build && vp run generate-readme && vp run copy-files",
    "build:api-docs": "typedoc",
    "build:docs": "vp run build:api-docs && vp run copy-package-docs && vitepress build",
    "copy-files": "find packages/fate packages/react-fate -type d -maxdepth 0 -exec cp README.md LICENSE {} \\; && cp LICENSE packages/void-fate/LICENSE",
    "copy-package-docs": "node --conditions=development --no-warnings --loader ts-node/esm scripts/copy-package-docs.ts",
    "dev": "npm-run-all --parallel dev:client dev:server",
    "dev:client": "cd example/client && vp dev",
    "dev:docs": "typedoc && vitepress dev",
    "dev:drizzle": "npm-run-all --parallel dev:client dev:drizzle-server",
    "dev:drizzle-server": "cd example/server-drizzle && vp run dev",
    "dev:server": "cd example/server-prisma && vp run dev",
    "dev:setup": "vp run --filter '@nkzw/fate' build && vp run --filter react-fate build && (cd example/server-prisma && vp run dev:setup) && vp run fate:generate",
    "dev:void": "cd example/void && vp dev",
    "fate:generate": "(cd example/client && node --conditions=development --no-warnings --loader ts-node/esm ../../packages/fate/src/cli.ts generate)",
    "generate-readme": "node --conditions=development --no-warnings --loader ts-node/esm scripts/generate-readme.ts",
    "prepare": "vp config",
    "prisma": "vp run --filter '@nkzw/fate-server' prisma",
    "ship": "vp run build:all && vp run build:api-docs && vp run copy-package-docs && vp check && vp test && vp pm publish -r --access public"
  },
  "devDependencies": {
    "@fontsource/fira-code": "^5.2.7",
    "@nkzw/eslint-plugin": "^2.0.0",
    "@nkzw/fate-server": "workspace:*",
    "@nkzw/find-workspaces": "^1.1.0",
    "@nkzw/oxlint-config": "^1.2.1",
    "@paper-design/shaders": "^0.0.76",
    "@rolldown/plugin-babel": "^0.2.3",
    "@swc/core": "^1.15.33",
    "@types/node": "^25.7.0",
    "@typescript/native-preview": "7.0.0-dev.20260513.1",
    "@vitest/coverage-v8": "4.1.6",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.4.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-workspaces": "^0.12.1",
    "happy-dom": "^20.9.0",
    "npm-run-all2": "^8.0.4",
    "oxc-minify": "^0.130.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitepress": "2.0.0-alpha.15",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.0.6"
}
