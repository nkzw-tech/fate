{
  "name": "@nkzw/fate-private",
  "version": "0.1.3",
  "private": true,
  "description": "fate is a modern data client for React.",
  "author": "Christoph Nakazawa <christoph.pojer@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git://github.com/nkzw-tech/fate.git"
  },
  "type": "module",
  "scripts": {
    "build:all": "vp run -r build && vp run generate-readme && vp run copy-files",
    "build:docs": "typedoc && vitepress build",
    "copy-files": "find packages/fate packages/react-fate -type d -maxdepth 0 -exec cp README.md LICENSE {} \\;",
    "dev": "npm-run-all --parallel dev:client dev:server",
    "dev:client": "cd example/client && vp dev",
    "dev:docs": "typedoc && vitepress dev",
    "dev:server": "cd example/server && vp dev",
    "dev:setup": "(cd example/server && vp run dev:setup)",
    "fate:generate": "node --conditions=development --no-warnings --loader ts-node/esm --env-file example/server/.env packages/fate/src/cli.ts generate @nkzw/fate-server/src/trpc/router.ts example/client/src/fate.ts",
    "generate-readme": "node --conditions=development --no-warnings --loader ts-node/esm scripts/generate-readme.ts",
    "preinstall": "command -v git >/dev/null 2>&1 && git config core.hooksPath git-hooks || exit 0",
    "prisma": "vp run --filter '@nkzw/fate-server' prisma",
    "ship": "vp run build:all && vp check && vp test && vp pm publish -r --access public"
  },
  "devDependencies": {
    "@fontsource/fira-code": "^5.2.7",
    "@nkzw/eslint-plugin": "^2.0.0",
    "@nkzw/fate-server": "workspace:*",
    "@nkzw/find-workspaces": "^1.1.0",
    "@nkzw/oxlint-config": "^1.0.1",
    "@paper-design/shaders": "^0.0.71",
    "@swc/core": "^1.15.10",
    "@types/node": "^25.0.10",
    "@typescript/native-preview": "7.0.0-dev.20260123.3",
    "@vitest/coverage-v8": "4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.2.3",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-workspaces": "^0.12.0",
    "happy-dom": "^20.3.7",
    "npm-run-all2": "^8.0.4",
    "oxc-minify": "^0.110.0",
    "prisma": "^7.3.0",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitepress": "2.0.0-alpha.15",
    "vitepress-plugin-llms": "^1.10.0",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.0"
}
