{
  "name": "@nkzw/fate-server-drizzle",
  "version": "0.0.0",
  "private": true,
  "author": "Christoph Nakazawa <christoph.pojer@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git://github.com/nkzw-tech/fate.git"
  },
  "type": "module",
  "scripts": {
    "db:check": "node --env-file=.env node_modules/drizzle-kit/bin.cjs check --config drizzle.config.ts",
    "db:generate": "node --env-file=.env node_modules/drizzle-kit/bin.cjs generate --config drizzle.config.ts",
    "db:migrate": "node --env-file=.env node_modules/drizzle-kit/bin.cjs migrate --config drizzle.config.ts",
    "db:push": "node --env-file=.env node_modules/drizzle-kit/bin.cjs push --config drizzle.config.ts",
    "db:seed": "node --no-warnings --experimental-specifier-resolution=node --loader ts-node/esm --env-file .env src/drizzle/seed.tsx",
    "dev": "NODE_ENV=development node_modules/.bin/nodemon -q -I --exec node --no-warnings --experimental-specifier-resolution=node --loader ts-node/esm --env-file .env src/index.tsx",
    "dev:setup": "vp run db:push && vp run db:seed",
    "drizzle": "drizzle-kit --config drizzle.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/trpc-server": "^0.4.2",
    "@nkzw/core": "^1.3.1",
    "@nkzw/define-env": "^1.1.0",
    "@nkzw/fate": "workspace:*",
    "@trpc/server": "^11.16.0",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.7",
    "nodemon": "^3.1.14"
  },
  "nodemonConfig": {
    "ext": "ts,tsx",
    "watch": [
      "src/"
    ]
  }
}
