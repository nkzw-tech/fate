{
  "name": "@nkzw/fate-server-cloudflare",
  "version": "0.0.0",
  "private": true,
  "author": "Christoph Nakazawa <christoph.pojer@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git://github.com/nkzw-tech/fate.git"
  },
  "type": "module",
  "scripts": {
    "db:migrate": "wrangler d1 migrations apply fate-cloudflare --local",
    "db:migrate:remote": "wrangler d1 migrations apply fate-cloudflare --remote",
    "deploy": "pnpm --filter cf-fate build && wrangler deploy",
    "dev": "pnpm --filter cf-fate build && pnpm run db:migrate && wrangler dev",
    "dev:worker": "wrangler dev",
    "fate:generate": "TS_NODE_PROJECT=../../tsconfig.json node --conditions=development --no-warnings --loader ts-node/esm ../../packages/fate/src/cli.ts generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nkzw/core": "^1.3.1",
    "@nkzw/fate": "workspace:*",
    "better-auth": "^1.6.23",
    "cf-fate": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "^4.111.0"
  }
}
